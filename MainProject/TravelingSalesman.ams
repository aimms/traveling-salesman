		Section FlagsIdentifier {
			Comment: "Contains flag identifiers used to control read-only state of WebUI widgets.";
			StringParameter sp_readOnlyFlag {
				Comment: "String constant 'readonly' used as a WebUI flags identifier to make widgets non-editable.";
