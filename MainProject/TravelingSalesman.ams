		Section Pages {
			Comment: "Contains all page-specific UI declarations and procedures.";
			Section Network_Page {
				Comment: "Contains declarations and procedures for the network page where cities are added and visualized.";
				StringParameter sp_mapTitle {
					Comment: "Dynamic title for the network map widget, showing the current number of nodes.";
					Definition: {
						"The network has " + card(s_nodes) + " nodes.";
					}
				}
				StringParameter sp_addThisCity {
					Comment: "City name entered by the user to fetch coordinates for a single city.";
					InitialData: "";
				}
				StringParameter sp_addByCountry {
					Comment: "Country name entered by the user to fetch random cities from that country.";
					InitialData: "";
				}
				Parameter p_def_unableToFetch {
					Comment: "Counter for cities whose coordinates could not be fetched from the API.";
					InitialData: 0;
					webui::FlagsIdentifier: sp_readOnlyFlag;
				}
				StringParameter sp_def_nodeTooltip {
					Comment: "HTML tooltip string for each node in the network map, showing city name, latitude, and longitude.";
					IndexDomain: i_city | exists(i_node1 | i_node1 = i_city) or exists(i_node2 | i_node2 = i_city);
					Definition: {
						"<p style=\"text-align: left;\"><em>" + i_city + "</em></p>" +
						"<p style=\"text-align: left;\"><strong>Latitude: </strong>" + p_latitude(i_city) + "</p>" +
						"<p style=\"text-align: left;\"><strong>Longitude: </strong>" + p_longitude(i_city) + "</p>"
					}
				}
				Parameter p_def_nodeSize {
					Comment: "Size parameter for nodes in the network map widget.";
					IndexDomain: i_city;
					Definition: 2;
					webui::TooltipIdentifier: sp_def_nodeTooltip(i_city);
				}
				StringParameter sp_def_arcTooltip {
					Comment: "HTML tooltip string for each arc in the network map, showing origin and destination cities.";
					IndexDomain: (i_node1,i_node2) | i_node1 <> i_node2;
					Definition: {
						"<p style=\"text-align: left;\">From <em>" + i_node1 + "</em> to <em>" + i_node2 + "</em>.</p>"
					}
				}
				StringParameter sp_def_nodeAnnotation {
					Comment: "CSS annotation class applied to all nodes in the default (non-algorithm-specific) network view.";
					IndexDomain: i_city;
					Definition: "node-done";
				}
				StringParameter sp_def_nodeItemActions {
					Comment: "Item action definitions for nodes in the network map, providing a delete button.";
					IndexDomain: (webui::indexWidgetItemActionSpec,webui::indexPageExtension,webui::indexWidgetActionSpec);
					Definition: {
						data 
						{ ( p_def_nodeSize, 1, displaytext ) : "Delete this node"  ,  ( p_def_nodeSize, 1, icon        ) : "aimms-cross" ,
						  ( p_def_nodeSize, 1, procedure   ) : "pr_deleteNode"  ,  ( p_def_nodeSize, 1, state       ) : "active" }
					}
				}
				StringParameter sp_def_networkSidePanel {
					Comment: "Side panel configuration for the network page, linking to the help page.";
					IndexDomain: (webui::indexPageExtension,webui::indexSidePanelSpec);
					Definition: data { ( 1, displayText ) : "Help",  ( 1, pageId ) : "network_help",  ( 1, icon ) : "aimms-info2",  ( 1, state ) : "active" };
				}
				StringParameter sp_def_addThisCityTooltipButton {
					Comment: "Tooltip text for the button that fetches coordinates for a specific city.";
					Definition: "Fetch " + sp_addThisCity + "'s latitude and longitude on PositionStack api.";
				}
				StringParameter p_def_addThisCountryTooltipButton {
					Comment: "Tooltip text for the button that fetches random cities from a specific country.";
					Definition: "Fetch " + p_maxCities + " random cities' latitude and longitude from " + sp_addByCountry + " on PositionStack api.";
				}
				StringParameter sp_def_addByLimitTooltipButton {
					Comment: "Tooltip text for the button that fetches a random set of cities up to the configured limit.";
					Definition: "Fetch " + p_maxCities + " random cities' latitude and longitude on PositionStack api.";
				}
				Procedure pr_addThisCity {
					Comment: "Fetches the latitude and longitude of the city entered in sp_addThisCity via the PositionStack API.";
					Body: {
						! Abort if no API key has been configured.
						if sp_apiKey = "" then
						    webui::ShowMessage('error',"No api selected.");   
						    return;
						endif;   
						
						! Look up the city element and retrieve its ASCII name and country.
						ep_city := StringToElement(s_cities, sp_addThisCity, 0);
						sp_loc_cityASCII := first(i_city_ascii | bp_city_x_cityASCII(ep_city, i_city_ascii));
						ep_loc_cityCountry := first(i_country | bp_city_x_country(ep_city, i_country));
						
						! Call the API query if the city was found; otherwise show an error message.
						if ep_loc_cityCountry then
						    pr_callAPIQuery(sp_loc_cityASCII, ep_loc_cityCountry);
						else
						    webui::ShowMessage('error',"No city with this name.");   
						endif;
					}
					ElementParameter ep_loc_cityCountry {
						Comment: "The country of the city being looked up, used to refine the API query.";
						Range: s_countries;
					}
					StringParameter sp_loc_cityASCII {
						Comment: "ASCII version of the city name used in the API request URL.";
					}
				}
				Procedure pr_addByCountry {
					Comment: "Fetches coordinates for up to p_maxCities random cities from the country entered in sp_addByCountry.";
					Body: {
						! Abort if no API key has been configured.
						if sp_apiKey = "" then
						    webui::ShowMessage('error',"No api selected.");    
						    return;
						endif;   
						
						empty ep_country;
						
						! Look up the selected country and initialize the fetch counter.
						ep_country := StringToElement(s_countries, sp_addByCountry, 0);
						p_loc_counter := 0;
						
						if sp_addByCountry and ep_country then
						    block 
						    ! Count the total number of cities available in the selected country.
						    p_loc_cardinalityOfCitiesFromCountry  
						    :=  sum(i_id | exists(i_city | 
						                    bp_city_x_id(i_city, i_id) 
						                    and bp_city_x_country(i_city, ep_country)), 1);
						
						    ! Build a sequential ID mapping to enable uniform random city selection.
						    s_loc_newIds := {1 .. p_loc_cardinalityOfCitiesFromCountry};
						    ep_loc_newId := first(i_loc_newid);
						
						    for i_id | exists(i_city | 
						                    bp_city_x_id(i_city, i_id) 
						                    and bp_city_x_country(i_city, ep_country)) do
						
						        bp_loc_oldId_x_newId(i_id, ep_loc_newId) :=  1;
						        ep_loc_newId += 1;
						    endfor;    
						    endblock;
						
						    ! Randomly select and fetch cities until the configured maximum is reached.
						    while p_loc_counter < p_maxCities do
						        p_loc_randomNewId := ceil(uniform(val(first(i_loc_newid)), val(last(i_loc_newid))));
						        ep_loc_newId := StringToElement(s_loc_newIds, p_loc_randomNewId, 0);
						        ep_city := first(i_city | exists(i_id |  bp_loc_oldId_x_newId(i_id, ep_loc_newId) and bp_city_x_id(i_city, i_id)));
						
						        sp_loc_cityASCII := first(i_city_ascii | bp_city_x_cityASCII(ep_city, i_city_ascii));
						
						        if ep_country and sp_loc_cityASCII then
						
						            ! Report progress to the WebUI progress indicator.
						            sp_loc_message := round(100 * (p_loc_counter/$ p_maxCities)) + " % - Fetching: " + sp_loc_cityASCII + " - " + ep_country;
						            webui::SetProgressMessage(sp_loc_message);
						
						            pr_callAPIQuery(sp_loc_cityASCII, ep_country);
						            p_loc_counter += 1;
						        endif;
						
						        ! Safety limit to prevent infinite loops on sparse data.
						        if  p_loc_counter > 2000 then
						            return 1;
						        endif;            
						    endwhile; 
						else 
						    webui::ShowMessage('error',"No country with this name.");   
						endif;
					}
					Set s_loc_newIds {
						Comment: "Temporary set of sequential IDs for shuffling cities within the selected country.";
						Index: i_loc_newid;
						Parameter: ep_loc_newId;
					}
					StringParameter sp_loc_cityASCII {
						Comment: "ASCII name of the city currently being fetched.";
					}
					StringParameter sp_loc_message {
						Comment: "Progress message string displayed in the WebUI progress indicator.";
					}
					ElementParameter ep_loc_cityCountry {
						Comment: "Element parameter for the selected country during batch fetching.";
						Range: s_countries;
					}
					Parameter p_loc_randomNewId {
						Comment: "Randomly selected index used to pick a city from the country's city list.";
					}
					Parameter p_loc_counter {
						Comment: "Counter tracking the number of cities successfully fetched so far.";
					}
					Parameter p_loc_cardinalityOfCitiesFromCountry {
						Comment: "Total number of cities available in the selected country.";
						InitialData: 1;
					}
					Parameter bp_loc_oldId_x_newId {
						Comment: "Binary mapping from original city IDs to sequential new IDs for random selection.";
						IndexDomain: (i_id,i_loc_newid);
						Range: binary;
					}
				}
				Procedure pr_addByLimit {
					Comment: "Fetches coordinates for up to p_maxCities randomly selected cities from the world cities database.";
					Body: {
						! Abort if no API key has been configured.
						if sp_apiKey = "" then
						    webui::ShowMessage('error',"No api selected.");   
						    return;
						endif;   
						
						! Initialize counters and clear previous city and country selections.
						empty ep_country, ep_city;
						p_loc_counter:= 0;
						
						! Randomly select cities from the database until the configured maximum is reached.
						while p_loc_counter < p_maxCities do
						    p_loc_randomId := ceil(uniform(val(first(i_id)), val(last(i_id))));
						    ep_id := StringToElement(s_ids, p_loc_randomId, 0);
						
						    ep_city := first(i_city | bp_city_x_id(i_city, ep_id));
						    ep_country := first(i_country | bp_city_x_country(ep_city, i_country));
						
						    sp_loc_cityASCII := first(i_city_ascii | bp_city_x_cityASCII(ep_city, i_city_ascii));
						
						    if ep_country and sp_loc_cityASCII then
						        ! Report progress to the WebUI progress indicator.
						        sp_loc_message := round(100 * (p_loc_counter/$ p_maxCities)) + " % - Fetching: " + sp_loc_cityASCII + " - " + ep_country;
						        webui::SetProgressMessage(sp_loc_message);
						
						        pr_callAPIQuery(sp_loc_cityASCII, ep_country);
						        p_loc_counter += 1;
						    endif;
						
						    ! Safety limit to prevent infinite loops if valid cities are sparse.
						    if  p_loc_counter > 2000 then
						        return 1;
						    endif;   
						endwhile;
					}
					Parameter p_loc_counter {
						Comment: "Counter tracking the number of cities successfully fetched so far.";
						InitialData: 0;
					}
					Parameter p_loc_randomId {
						Comment: "Randomly selected database ID for picking a city.";
					}
					StringParameter sp_loc_cityASCII {
						Comment: "ASCII name of the city currently being fetched.";
					}
					StringParameter sp_loc_message {
						Comment: "Progress message displayed in the WebUI progress indicator.";
					}
				}
				Procedure pr_cleanAllNodes {
					Comment: "Clears all API input data and resets all tour solutions.";
					Body: {
						! Clear all API-fetched node data (coordinates, sets).
						empty API_Inputs;
						! Reset all heuristic tour connection parameters.
						pr_clearSolutions;
					}
				}
				Procedure pr_deleteNode {
					Comment: "Removes the selected node from the active network by emptying its latitude and longitude.";
					Body: {
						! Remove the selected city from the active network by clearing its coordinates.
						empty p_latitude(ep_city);
						empty p_longitude(ep_city);
					}
				}
			}
			Section Heuristic_Page {
				Comment: "Contains declarations and procedures for the heuristic solutions page.";
				StringParameter sp_def_heuristicPrimaryActions {
