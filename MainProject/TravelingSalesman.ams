	}
	Section Integration {
		Comment: "Contains all integration sections for database and API connectivity.";
		Section World_Cities_DB {
			Comment: "Contains declarations and procedures for reading world cities data from a SQLite database.";
			Procedure pr_readWorldCities {
				Comment: "Reads world city data from the SQLite database and populates all city, country, province, and ID sets.";
				Body: {
					! Clear any previously loaded world city data.
					empty World_Cities_DB;
					! Read all rows from the SQLite worldCities database table.
					read from table db_worldCities;
					
					! Populate AIMMS sets and cross-reference parameters from the database rows.
					if exists(i_int_id | sp_int_city(i_int_id)) then
					
					    for i_int_id | sp_int_city(i_int_id) do
					        ep_id := StringToElement(s_ids, val(i_int_id) + 10000, 1); 
					        SetElementAdd(s_cities, ep_city, sp_int_city(i_int_id));
					        SetElementAdd(s_citiesASCII, ep_cityASCII, sp_int_cityASCII(i_int_id));
					        SetElementAdd(s_countries, ep_country, sp_int_country(i_int_id));
					        SetElementAdd(s_provinces, ep_province, sp_int_province(i_int_id));
					
					        sp_countryAcronym(ep_country) := sp_int_countryAcronym(i_int_id);
					
					        ! Link each city to its country, ASCII name, province, and database ID.
					        bp_city_x_country(ep_city,ep_country) := 1;
					        bp_city_x_cityASCII(ep_city, ep_cityASCII) := 1;
					        bp_city_x_province(ep_city, ep_province) := 1;
					        bp_city_x_id(ep_city, ep_id) := 1;
					    endfor;
					endif;
				}
			}
			StringParameter sp_def_dataSource {
				Comment: "ODBC connection string for the WorldCities SQLite database.";
				Definition: {
					SQLCreateConnectionString (
					       DatabaseInterface              :  'odbc',
					       DriverName                     :  sp_def_driverName, !Your local drive
					       ServerName                     :  "", 
					       DatabaseName                   :  "WorldCities.db", !The path of your database
					       UserId                         :  "", 
					       Password                       :  "", 
					       AdditionalConnectionParameters :  "");
				}
			}
			StringParameter sp_def_driverName {
				Comment: "ODBC driver name, switching between 'SQLite3' for PRO/non-developer mode and 'SQLite3 ODBC Driver' for local development.";
				Definition: {
					if pro::GetPROEndPoint() or not ProjectDeveloperMode() then
					    "SQLite3"
					else 
					    "SQLite3 ODBC Driver"    
					endif;
				}
			}
			DatabaseTable db_worldCities {
				Comment: "Database table declaration mapping the worldCities SQLite table to AIMMS identifiers.";
				DataSource: sp_def_dataSource;
				TableName: "worldCities";
				Mapping: {
					"ID"   -->i_int_id,
					"City" -->sp_int_city,
					"CityASCII" -->sp_int_cityASCII,
					"Country" -->sp_int_country,
					"ISO" -->sp_int_countryAcronym,
					"Province" -->sp_int_province
				}
			}
			Set s_int_id {
				Comment: "Set of integer IDs from 1 to 7400 representing the rows in the world cities database.";
				Index: i_int_id;
				Definition: {
					{1..7400}
				}
			}
			StringParameter sp_int_city {
				Comment: "City name for each database row, read from the worldCities table.";
				IndexDomain: i_int_id;
			}
			StringParameter sp_int_cityASCII {
				Comment: "ASCII city name for each database row, used in API queries.";
				IndexDomain: i_int_id;
			}
			StringParameter sp_int_country {
				Comment: "Country name for each database row.";
				IndexDomain: i_int_id;
			}
			StringParameter sp_int_province {
				Comment: "Province or state name for each database row.";
				IndexDomain: i_int_id;
			}
			StringParameter sp_int_countryAcronym {
				Comment: "ISO country code for each database row.";
				IndexDomain: i_int_id;
			}
		}
		Section LatLong_API {
			Comment: "Contains declarations and procedures for fetching latitude/longitude via the PositionStack API.";
			StringParameter sp_apiKey {
				Comment: "API key for the PositionStack geocoding service, required for all API calls.";
			}
			Procedure pr_callAPIQuery {
				Comment: "Constructs and executes a PositionStack API request to fetch latitude/longitude for a given city and country.";
				Arguments: (sp_in_city,ep_in_cityCountry);
				Body: {
					! Delete any output files from a previous API call.
					if DirectoryExists("out") then
					    DirectoryDelete("out");
					endif;
					DirectoryCreate("out");
					
					block ! Build and execute the PositionStack API request for the given city and country.
					sp_loc_requestId := "fetch" + sp_in_city;
					
					sp_in_city := FindReplaceStrings(sp_in_city, " ", "%20");
					
					sp_loc_urlCall 
					:=  "http://api.positionstack.com/v1/forward?access_key=" + sp_apiKey 
					    + "&query=" + sp_in_city 
					    + "&limit=1"
					    + "&country=" + sp_countryAcronym(ep_in_cityCountry);
					
					dex::client::NewRequest(
					        sp_loc_requestId,
					        sp_loc_urlCall,
					        'dex::client::EmptyCallback',
					        responsefile:"out/Output.json",
					        tracefile:"Trace.xml");
					
					dex::client::PerformRequest(sp_loc_requestId);
					dex::client::WaitForResponses(2000);    
					endblock;
					
					! Wait for the HTTP response to arrive before reading the output file.
					delay(5);
					
					! Parse the JSON response file and update the model with the retrieved coordinates.
					pr_readJSONOutput;
				}
				StringParameter sp_in_city {
					Comment: "City name (ASCII) to search for; spaces are replaced with %20 for URL encoding.";
					Property: Input;
				}
				ElementParameter ep_in_cityCountry {
					Comment: "Country of the city being queried, used to retrieve the ISO country code.";
					Range: s_countries;
					Property: Input;
				}
				StringParameter sp_loc_urlCall {
					Comment: "Full URL string for the PositionStack API request.";
				}
				StringParameter sp_loc_requestId {
					Comment: "Unique request identifier used with the DEX HTTP client.";
				}
			}
			Section Read_JSON_by_DEX {
				Comment: "Contains DEX-based declarations and the procedure to parse JSON API responses.";
				DeclarationSection LatLong {
					Comment: "DEX dataset declarations for mapping JSON latitude/longitude response fields.";
					dex::Dataset: LatLongDataset;
					dex::TableName: LatLong;
					Set s_int_cities {
						Comment: "Set of city names returned by the DEX JSON mapping from the API response.";
						Parameter: ep_int_city;
					}
					Index i_int_city {
						Comment: "Index over s_int_cities, mapped to the 'name' column in the API JSON response.";
						Range: s_int_cities;
						dex::ColumnName: name;
					}
					Parameter p_int_latitude {
						Comment: "Latitude value for each city in the API JSON response.";
						IndexDomain: i_int_city;
						dex::ColumnName: latitude;
					}
					Parameter p_int_longitude {
						Comment: "Longitude value for each city in the API JSON response.";
						IndexDomain: i_int_city;
						dex::ColumnName: longitude;
					}
				}
				Procedure pr_readJSONOutput {
					Comment: "Reads and maps the PositionStack JSON API response file using DEX, then updates latitude and longitude for the fetched city.";
					Body: {
						! Register the DEX mapping that describes the JSON response structure.
						dex::AddMapping(
							mappingName :  "LatLongMapping", 
							mappingFile :  "Mappings/Generated/LatLongDataset.xml");
						
						! Read the JSON output file into the DEX dataset identifiers.
						dex::ReadFromFile(
							dataFile         :  "out/Output.json", 
							mappingName      :  "LatLongMapping", 
							emptyIdentifiers :  1, 
							emptySets        :  1, 
							resetCounters    :  1);
						
						! Map the DEX result to the main data model.
						empty ep_city;
						ep_int_city := first(i_int_city);
						sp_loc_city := ep_int_city;
						
						! Normalize accented characters in the returned city name to match the database.
						pr_checkReplaceCharacters(sp_loc_city);
						
						ep_city := StringToElement(s_cities, sp_loc_city, 1);
						
						if ep_city then
						    p_latitude(ep_city) := p_int_latitude(ep_int_city);
						    p_longitude(ep_city) := p_int_longitude(ep_int_city);
						    sp_def_cycNodeAnnotation(ep_city) := "node-done";
						    sp_def_simNodeAnnotation(ep_city) := "node-done";
						
						else
						    ! City name returned by API was not recognized; increment the failure counter.
						    p_def_unableToFetch += 1;
						endif;
					}
					StringParameter sp_loc_city {
						Comment: "City name extracted from the DEX mapping result, used to match against s_cities.";
					}
				}
			}
		}
	}
	Section Toolkit {
		Comment: "Contains utility procedures used throughout the model.";
		Procedure pr_checkReplaceCharacters {
			Arguments: (sp_inout_string);
			Body: {
				! Replace accented and special characters with their plain ASCII equivalents.
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ã", "a");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "é", "e");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "á", "a");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "õ", "o");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "è", "e");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "í", "i");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ì", "i");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ó", "o");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ò", "o");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ú", "u");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ù", "u");
				sp_inout_string := FindReplaceStrings(sp_inout_string, "ñ", "n");
			}
			Comment: "í";
			StringParameter sp_inout_string {
				Comment: "Input/output string parameter where special characters are replaced with ASCII equivalents.";
				Property: InOut;
			}
		}
		Procedure pr_scheduleOver {
			Arguments: (p_in_noSecs,ep_in_payLoad);
			Body: {
				block ! Sanity checks: verify that the delay is positive and the payload is non-empty.
					if p_in_noSecs <= 0[s] then
						raise error 
							formatString("pr_scheduleOver(%n,%e): The number of seconds should be strictly positive.", 
								p_in_noSecs, ep_in_payLoad);
					endif ;
					if not ep_in_payLoad then
						raise error 
							formatString("pr_scheduleOver(%n,%e): Empty payload specified.", 
								p_in_noSecs, ep_in_payLoad);
					endif ;
				endblock ;
				
				block ! Is the reference date based on UTC?
					p_loc_ogv 
					:=  OptionGetValue(
				            OptionName :  "use_UTC_forCaseAndStartEndDate", 
				            Lower      :  p_loc_low, 
				            Current    :  p_loc_scheduleAtUsesUTC, 
				            Default    :  p_loc_def, 
				            Upper      :  p_loc_lupp);
				
					if not p_loc_ogv then ! Option use_UTC_forCaseAndStartEndDate is introduced with AIMMS 4.75.
						p_loc_scheduleAtUsesUTC := 0 ; ! Assume option use_UTC_forCaseAndStartEndDate is off.
					endif ;
				endblock ;
				
				sp_loc_refDate := "2023-01-01 00:00:00" ;
				
				p_loc_tmpSec := CurrentToMoment([s], sp_loc_refDate) ;
				p_loc_tmpSec += p_in_noSecs ;
				
				if p_loc_scheduleAtUsesUTC then
					sp_loc_launchDate := MomentToString( "%c%y-%m-%d %H:%M:%S%TZ('UTC')", [s], sp_loc_refDate, p_loc_tmpSec );
				else
					sp_loc_launchDate := MomentToString( "%c%y-%m-%d %H:%M:%S", [s], sp_loc_refDate, p_loc_tmpSec );
				endif ;
				
				! Note: ScheduleAt is precise up to a second.
				if not ScheduleAt(sp_loc_launchDate, ep_in_payLoad) then
				    raise error "Error scheduling procedure \'" + ep_in_payLoad + "\': " + CurrentErrorMessage code 'Schedule-at-procedure' ;
				endif;
			}
			Comment: "Schedule a job in a couple of seconds.";
			Parameter p_in_noSecs {
				Comment: "Number of seconds to wait before scheduling the payload procedure.";
				Unit: s;
				Property: Input;
			}
			ElementParameter ep_in_payLoad {
				Comment: "Procedure to be scheduled for execution after the specified delay.";
				Range: AllProcedures;
				Property: Input;
			}
			StringParameter sp_loc_refDate {
				Comment: "Reference date string used as the base for moment calculations.";
			}
			StringParameter sp_loc_launchDate {
				Comment: "Computed launch date-time string passed to ScheduleAt.";
			}
			Parameter p_loc_tmpSec {
				Comment: "Temporary parameter holding the computed scheduled time in seconds.";
				Range: integer;
				Unit: s;
			}
			Parameter p_loc_ogv {
				Comment: "Return value of OptionGetValue for the UTC option check.";
			}
			Parameter p_loc_low {
				Comment: "Lower bound returned by OptionGetValue.";
			}
			Parameter p_loc_scheduleAtUsesUTC {
				Comment: "Flag indicating whether the ScheduleAt function uses UTC time.";
			}
			Parameter p_loc_def {
				Comment: "Default value returned by OptionGetValue.";
			}
			Parameter p_loc_lupp {
				Comment: "Upper bound returned by OptionGetValue.";
			}
		}
	}
	Procedure MainInitialization {
		Comment: "Initializes the model by clearing all tour data and setting the status bar to 'Ready'.";
		Body: {
			empty p_init_tourConnect,p_sim_tourConnect,p_cyc_tourConnect;
			
			p_init_tourInitialized := 0;
			p_sim_initialized  := 0;
			p_cyc_initialized  := 0;
			
			block ! Set the status bar to the Ready state on initialization.
			    sp_statusBar('1', 'icon') := "aimms-circle2";
			    sp_statusBar('1', 'color') := "var(--secondary)";
			    sp_statusBar('1', 'text') := "Ready";
			    sp_statusBar('1', 'tooltip') := "The run is completed.";
			    sp_statusBar('1', 'state') := "active";
			endblock;
		}
	}
	Procedure PostMainInitialization {
		Comment: "Post-initialization hook; currently unused but available for future initialization logic.";
	}
	Procedure pr_pageopenWelcome {
		Comment: "Page open procedure for the welcome page; reads world cities from the database if available.";
		Body: {
			! Test the database connection before attempting to load city data.
			if TestDataSource(sp_def_dataSource) then
				! Database is reachable; populate the world cities sets and parameters.
				pr_readWorldCities();
			else
				! Database connection failed; warn the user so they can check the data source.
			    webui::ShowMessage('warning', "Lack of connection with Database.");
			endif ;
		}
	}
	Procedure MainExecution {
		Comment: "Main execution procedure; currently unused as solving is triggered via UI actions.";
	}
	Procedure PreMainTermination {
		Comment: "Pre-termination hook that returns 1 to allow clean shutdown without prompting to save.";
		Body: {
			return 1;
		}
	}
	Procedure MainTermination {
		Body: {
			return 1 ;
		}
		Comment: "We return 1 to make sure AIMMS does not ask to save a case when closing the project";
	}
}
