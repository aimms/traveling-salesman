				StringParameter sp_titleImprovedTourCyclic {
					Comment: "Title string for the cyclic improved tour network widget.";
					InitialData: "Improved Tour (Cyclic)";
				}
				Procedure pr_checkIterativeCyclic {
					Comment: "Shows a confirmation dialog before starting the iterative cyclic improvement algorithm.";
					Body: {
						! Define the available dialog response options.
						s_loc_actions := {'No!', 'Yes'};
						
						! Show a confirmation dialog warning that the algorithm may take some time to complete.
						webui::RequestPerformWebUIDialog(
							title   :  "Good to know", 
							message :  "This procedure can take a while but you will see the map changing connections. \nDo you want to proceed?", 
							actions :  s_loc_actions, 
							onDone  :  'pr_refreshingImproveTourCyclic');
					}
					Set s_loc_actions {
						Comment: "Set of dialog button options presented to the user.";
					}
				}
				Procedure pr_checkIterativeSimultaneous {
					Comment: "Shows a confirmation dialog before starting the iterative simultaneous improvement algorithm.";
					Body: {
						! Define the available dialog response options.
						s_loc_actions := {'No!', 'Yes'};
						
						! Show a confirmation dialog warning that the algorithm may take some time to complete.
						webui::RequestPerformWebUIDialog(
							title   :  "Good to know", 
							message :  "This procedure can take a while but you will see the map changing connections. \nDo you want to proceed?", 
							actions :  s_loc_actions, 
							onDone  :  'pr_refreshingImproveTourSimultaneous');
					}
					Set s_loc_actions {
						Comment: "Set of dialog button options presented to the user.";
					}
				}
			}
